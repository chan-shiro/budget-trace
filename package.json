{
  "name": "yosan-trace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun pipeline/sync-public-sources.ts && next dev",
    "build": "bun pipeline/sync-public-sources.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pipeline:fetch": "bun pipeline/fetch.ts",
    "pipeline:ingest": "bun pipeline/ingest-local.ts",
    "pipeline:parse": "bun pipeline/parse.ts",
    "pipeline:validate": "bun pipeline/validate.ts",
    "pipeline:normalize": "bun pipeline/normalize.ts",
    "pipeline:fixture": "bun pipeline/dev/make-fixture.ts",
    "pipeline:derive": "bun pipeline/derive-app-data.ts",
    "pipeline:archive": "bun pipeline/archive.ts"
  },
  "dependencies": {
    "next": "^16.2.10",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "5.5.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "//": "next が postcss 8.4.31 を固定するが GHSA-qx2v-qp2m-jg93（CSS stringify の XSS）があるため 8.x 内で最新へ上げる",
    "postcss": "^8.5.19"
  }
}
