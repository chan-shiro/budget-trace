{
  "name": "yosan-trace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun pipeline/sync-public-sources.ts && next dev",
    "build": "bun pipeline/sync-public-sources.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pipeline:fetch": "bun pipeline/fetch.ts",
    "pipeline:ingest": "bun pipeline/ingest-local.ts",
    "pipeline:parse": "bun pipeline/parse.ts",
    "pipeline:validate": "bun pipeline/validate.ts",
    "pipeline:normalize": "bun pipeline/normalize.ts",
    "pipeline:fixture": "bun pipeline/dev/make-fixture.ts",
    "pipeline:derive": "bun pipeline/derive-app-data.ts",
    "pipeline:archive": "bun pipeline/archive.ts"
  },
  "dependencies": {
    "next": "^14.2.35",
    "pdfjs-dist": "^6.1.200",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "typescript": "5.5.3"
  }
